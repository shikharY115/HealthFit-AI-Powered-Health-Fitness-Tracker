# ============================================================
# Health & Fitness App — Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# --- App ---
NODE_ENV=development
PORT=5000

# --- MongoDB Atlas ---
# Get free cluster at: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/healthfit?retryWrites=true&w=majority

# --- JWT ---
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# --- CORS ---
CLIENT_URL=http://localhost:5173

# --- USDA FoodData Central API (Free) ---
# Register at: https://fdc.nal.usda.gov/api-guide.html
USDA_API_KEY=DEMO_KEY

# --- Google Gemini AI (Free) ---
# Get key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Fit / Google OAuth ---
# Set up at: https://console.cloud.google.com/
# Enable "Fitness API" and create OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/steps/google/callback
